        Size = UDim2.new(0,14,1,0),
        Position = UDim2.new(1,-16,0,0),
        BackgroundTransparency = 1,
        Text = "▾",
        TextColor3 = T.TextMuted,
        TextSize = 9,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Center,
        Parent = Cat,
    })

    Cat.MouseButton1Click:Connect(function()
        collapsed = not collapsed
        Arrow.Text = collapsed and "▸" or "▾"
        TFast(Arrow, { TextColor3 = collapsed and T.AccentBright or T.TextMuted })
        for _, btn in ipairs(linkedTabs) do
            if btn and btn.Parent then btn.Visible = not collapsed end
        end
    end)

    Cat.MouseEnter:Connect(function() TFast(CatTxt, { TextColor3 = T.Text }) end)
    Cat.MouseLeave:Connect(function() TFast(CatTxt, { TextColor3 = T.TextMuted }) end)

    local catObj = {
        Instance = Cat,
        LinkTab = function(_, btn)
            table.insert(linkedTabs, btn)
            btn.Visible = not collapsed
        end
    }
    self.Categories[categoryName] = catObj
    return catObj
end

