        for i=0,6 do table.insert(hueColors, Color3.fromHSV(i/6,1,1)) end
        Gradient(HueBar, hueColors, 90)

        local HueThumb = New("Frame", {
            Size = UDim2.new(1,4,0,4),
            Position = UDim2.new(0,-2,h,-2),
            BackgroundColor3 = Color3.fromRGB(255,255,255),
            BorderSizePixel = 0,
            ZIndex = 5,
            Parent = HueBar,
        })
        Corner(HueThumb, 3)
        Stroke(HueThumb, Color3.fromRGB(0,0,0), 1.5)

        -- RGB labels
        local RGBLabel = New("TextLabel", {
            Size = UDim2.new(1,0,0,20),
            Position = UDim2.new(0,0,0,98),
            BackgroundTransparency = 1,
            Text = string.format("R:%d G:%d B:%d", math.floor(color.R*255), math.floor(color.G*255), math.floor(color.B*255)),
            TextColor3 = T.TextDim,
            TextSize = 10,
            Font = Enum.Font.GothamMedium,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = Panel,
        })

        local function UpdateColor(fire)
            color = Color3.fromHSV(h, s, v)
            Swatch.BackgroundColor3 = color
            SVBox.BackgroundColor3 = Color3.fromHSV(h,1,1)
            RGBLabel.Text = string.format("R:%d G:%d B:%d", math.floor(color.R*255), math.floor(color.G*255), math.floor(color.B*255))
            if fire then pcall(act, color) end
        end

        local draggingSV, draggingHue = false, false

        SVBox.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then draggingSV = true end
        end)
        HueBar.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then draggingHue = true end
        end)
        UserInputService.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
                draggingSV = false; draggingHue = false
            end
        end)
        UserInputService.InputChanged:Connect(function(inp)
            if inp.UserInputType ~= Enum.UserInputType.MouseMovement and inp.UserInputType ~= Enum.UserInputType.Touch then return end
            if draggingSV then
                local abs, sz = SVBox.AbsolutePosition, SVBox.AbsoluteSize
                if sz.X <= 0 or sz.Y <= 0 then return end
                s = math.clamp((inp.Position.X-abs.X)/sz.X, 0, 1)
                v = 1 - math.clamp((inp.Position.Y-abs.Y)/sz.Y, 0, 1)
                SVThumb.Position = UDim2.new(s,0,1-v,0)
                UpdateColor(true)
            elseif draggingHue then
                local abs, sz = HueBar.AbsolutePosition, HueBar.AbsoluteSize
                if sz.Y <= 0 then return end
                h = math.clamp((inp.Position.Y-abs.Y)/sz.Y, 0, 1)
                HueThumb.Position = UDim2.new(0,-2,h,-2)
                UpdateColor(true)
            end
        end)

        Swatch.MouseButton1Click:Connect(function()
            open = not open
            if open then
                TSpring(Root, { Size = UDim2.new(1,-4,0,178) })
            else
                TSpring(Root, { Size = UDim2.new(1,-4,0,40) })
            end
        end)

        table.insert(self.Library.ControlRegistry, { Kind = "ColorPicker", Root = Root, RootStroke = RootStroke, Title = Label })
        table.insert(self.Elements, { Name = text, Instance = Root })

        return {
            GetValue = function() return color end,
            SetValue = function(c, fire)
                color = c
                h,s,v = Color3.toHSV(c)
                SVThumb.Position = UDim2.new(s,0,1-v,0)
                HueThumb.Position = UDim2.new(0,-2,h,-2)
                UpdateColor(fire)
            end
        }
    end


