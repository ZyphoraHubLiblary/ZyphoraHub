            TextColor3 = T.TextMuted,
            TextSize = 11,
            Font = Enum.Font.GothamBold,
            TextXAlignment = Enum.TextXAlignment.Center,
            Parent = Root,
        })

        local Sep = New("Frame", {
            Size = UDim2.new(1,-24,0,1),
            Position = UDim2.new(0,12,0,39),
            BackgroundColor3 = T.Border,
            BorderSizePixel = 0,
            Parent = Root,
        })

        local OptHolder = New("Frame", {
            Size = UDim2.new(1,0,0,0),
            Position = UDim2.new(0,0,0,40),
            BackgroundTransparency = 1,
            ClipsDescendants = true,
            Parent = Root,
        })
        local OptScroll = New("ScrollingFrame", {
            Size = UDim2.new(1,-8,1,0),
            Position = UDim2.new(0,4,0,0),
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            ScrollBarThickness = 2,
            ScrollBarImageColor3 = T.Border,
            CanvasSize = UDim2.new(0,0,0,0),
            Parent = OptHolder,
        })
        local OptLayout = New("UIListLayout", {
            SortOrder = Enum.SortOrder.LayoutOrder,
            Padding = UDim.new(0,3),
            Parent = OptScroll,
        })

        local function GetSelectedList()
            local out = {}
            for _, opt in ipairs(list) do
                if selected[opt] then table.insert(out, opt) end
            end
            return out
        end

        local function RefreshSummary()
            local sel = GetSelectedList()
            if #sel == 0 then
                ValLbl.Text = "Tidak ada yang dipilih"
            elseif #sel <= 2 then
                ValLbl.Text = table.concat(sel, ", ")
            else
                ValLbl.Text = sel[1] .. ", " .. sel[2] .. " +" .. (#sel-2)
            end
        end

        local function Rebuild()
            for _, c in ipairs(OptScroll:GetChildren()) do
                if c:IsA("TextButton") then c:Destroy() end
            end
            for i, opt in ipairs(list) do
                local isSel = selected[opt] == true
                local Btn = New("TextButton", {
                    Name = "Opt" .. i,
                    Size = UDim2.new(1,0,0,26),
                    BackgroundColor3 = isSel and T.SurfaceTop or T.SurfaceHigh,
                    Text = "",
                    BorderSizePixel = 0,
                    Parent = OptScroll,
                })
                Corner(Btn, 5)
                if isSel then Stroke(Btn, T.Accent, 1) end

                -- Checkbox
                local Box = New("Frame", {
                    Size = UDim2.new(0,16,0,16),
                    Position = UDim2.new(0,6,0.5,-8),
                    BackgroundColor3 = isSel and T.Accent or T.SurfaceHigh,
                    BorderSizePixel = 0,
                    Parent = Btn,
                })
                Corner(Box, 4)
                Stroke(Box, isSel and T.Accent or T.Border, 1)
                if isSel then
                    New("TextLabel", {
                        Size = UDim2.new(1,0,1,0),
                        BackgroundTransparency = 1,
                        Text = "✓",
                        TextColor3 = Color3.fromRGB(255,255,255),
                        TextSize = 10,
                        Font = Enum.Font.GothamBold,
                        TextXAlignment = Enum.TextXAlignment.Center,
                        Parent = Box,
                    })
                end

                New("TextLabel", {
                    Size = UDim2.new(1,-32,1,0),
                    Position = UDim2.new(0,28,0,0),
                    BackgroundTransparency = 1,
                    Text = tostring(opt),
                    TextColor3 = isSel and T.AccentBright or T.Text,
                    TextSize = 11,
                    Font = isSel and Enum.Font.GothamBold or Enum.Font.GothamMedium,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = Btn,
                })

                Btn.MouseEnter:Connect(function() TFast(Btn, { BackgroundColor3 = T.SurfaceTop }) end)
                Btn.MouseLeave:Connect(function() TFast(Btn, { BackgroundColor3 = isSel and T.SurfaceTop or T.SurfaceHigh }) end)
                Btn.MouseButton1Click:Connect(function()
                    selected[opt] = not selected[opt] or nil
                    if selected[opt] == nil then selected[opt] = nil end
                    RefreshSummary()
                    Rebuild()
                    pcall(act, GetSelectedList())
                end)
            end
            local h = math.min(OptLayout.AbsoluteContentSize.Y + 4, 130)
            OptScroll.CanvasSize = UDim2.new(0,0,0, OptLayout.AbsoluteContentSize.Y + 4)
            return h
        end

        Root.MouseButton1Click:Connect(function()
            open = not open
            if open then
                local h = Rebuild()
                TSpring(OptHolder, { Size = UDim2.new(1,0,0,h) })
                TSpring(Root, { Size = UDim2.new(1,-4,0,40+h+6) })
                TFast(RootStroke, { Color = T.Accent })
                ArrowLbl.Text = "▴"
            else
                TFast(OptHolder, { Size = UDim2.new(1,0,0,0) })
                TFast(Root, { Size = UDim2.new(1,-4,0,40) })
                TFast(RootStroke, { Color = T.Border })
                ArrowLbl.Text = "▾"
            end
        end)

        RefreshSummary()

        table.insert(self.Library.ControlRegistry, { Kind = "MultiDropdown", Root = Root, RootStroke = RootStroke, Title = Lbl, ValLabel = ValLbl })
        table.insert(self.Elements, { Name = text, Instance = Root })

        return {
            GetValue = function() return GetSelectedList() end,
            SetValue = function(arr, fire)
                selected = {}
                for _, v in ipairs(arr or {}) do selected[v] = true end
                RefreshSummary()
                if open then Rebuild() end
                if fire then pcall(act, GetSelectedList()) end
            end
        }
    end


