        })
        Corner(El, 8)
        local ElStroke = Stroke(El, T.Border, 1)

        local Icon = nil
        if iconId then
            local function ResolveIcon(icon)
                if typeof(icon) == "number" then return "rbxassetid://" .. tostring(icon) end
                return icon
            end
            Icon = New("ImageLabel", {
                Size = UDim2.new(0,14,0,14),
                Position = UDim2.new(0,12,0.5,-7),
                BackgroundTransparency = 1,
                Image = ResolveIcon(iconId) or "",
                ImageColor3 = T.TextMuted,
                Parent = El,
            })
        end

        local xOff = iconId and 32 or 12
        local Label = New("TextLabel", {
            Size = UDim2.new(1,-xOff-90,1,0),
            Position = UDim2.new(0,xOff,0,0),
            BackgroundTransparency = 1,
            Text = text,
            TextColor3 = T.Text,
            TextSize = 12,
            Font = Enum.Font.GothamMedium,
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = El,
        })

        local KeyBtn = New("TextButton", {
            Name = "KeyBtn",
            Size = UDim2.new(0,76,0,26),
            Position = UDim2.new(1,-86,0.5,-13),
            BackgroundColor3 = T.SurfaceHigh,
            Text = currentKey == Enum.KeyCode.Unknown and "..." or currentKey.Name,
            TextColor3 = T.AccentBright,
            TextSize = 11,
            Font = Enum.Font.GothamBold,
            BorderSizePixel = 0,
            Parent = El,
        })
        Corner(KeyBtn, 6)
        local KeyStroke = Stroke(KeyBtn, T.Accent, 1)

        KeyBtn.MouseButton1Click:Connect(function()
            if listening then return end
            listening = true
            KeyBtn.Text = "..."
            TFast(KeyStroke, { Color = T.Warning })
        end)

        local conn1, conn2
        conn1 = UserInputService.InputBegan:Connect(function(input, processed)
            if not listening then return end
            if input.UserInputType == Enum.UserInputType.Keyboard then
                currentKey = input.KeyCode
                KeyBtn.Text = currentKey.Name
                listening = false
                TFast(KeyStroke, { Color = T.Accent })
            end
        end)
        -- Fire callback saat key ditekan (di luar mode listening)
        conn2 = UserInputService.InputBegan:Connect(function(input, processed)
            if listening or processed then return end
            if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == currentKey and currentKey ~= Enum.KeyCode.Unknown then
                pcall(act, currentKey)
            end
        end)

        El.Destroying = El.Destroying or nil -- safety
        El.AncestryChanged:Connect(function(_, parent)
            if not parent then
                if conn1 then conn1:Disconnect() end
                if conn2 then conn2:Disconnect() end
            end
        end)

        El.MouseEnter:Connect(function() TFast(ElStroke, { Color = T.BorderLight }) end)
        El.MouseLeave:Connect(function() TFast(ElStroke, { Color = T.Border }) end)

        table.insert(self.Library.ControlRegistry, { Kind = "Keybind", Root = El, RootStroke = ElStroke, Title = Label, Icon = Icon })
        table.insert(self.Elements, { Name = text, Instance = El })

        return {
            GetKey = function() return currentKey end,
            SetKey = function(k) currentKey = k; KeyBtn.Text = k.Name end,
        }
    end


