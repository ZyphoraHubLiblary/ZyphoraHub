        SettingsTab:AddButton("Terapkan Custom Theme", 10723344432, function()
            local accent = HexToColor(accentInput:GetValue(), self.Theme.Accent)
            local bg = HexToColor(bgInput:GetValue(), self.Theme.BG)
            local function sh(c, f) return Color3.fromRGB(math.clamp(math.floor(c.R*255*f),0,255), math.clamp(math.floor(c.G*255*f),0,255), math.clamp(math.floor(c.B*255*f),0,255)) end
            self.Theme.Accent = accent; self.Theme.AccentBright = sh(accent,1.4); self.Theme.AccentDim = sh(accent,0.7)
            self.Theme.BG = bg; self.Theme.BGSecondary = sh(bg,1.5); self.Theme.BGTertiary = sh(bg,2)
            self.Theme.Surface = sh(bg,2.5); self.Theme.SurfaceHigh = sh(bg,3.2); self.Theme.SurfaceTop = sh(bg,3.8)
            self.Theme.Border = sh(bg,4.5); self.Theme.BorderLight = sh(bg,6.5)
            self.Theme.TextMuted = sh(bg,9)
            self:ApplyTheme()
            self:Notify("Tema Kustom", "Berhasil diterapkan.", "success")
        end)

        SettingsTab:AddButton("Reset Default", 10723344432, function()
            ApplyPreset("Default"); presetDrop:SetValue("Default", false)
            if self.SettingsRefs.AccentBox then self.SettingsRefs.AccentBox.Text = "#6C3BFF" end
            if self.SettingsRefs.BackgroundBox then self.SettingsRefs.BackgroundBox.Text = "#08080E" end
            self:Notify("Tema", "Dikembalikan ke Default.", "success")
        end)

        SettingsTab:AddSectionDivider("Custom Background")
        local bgLinkInput = SettingsTab:AddInput("Link/ID Background (semua link didukung)", 10723344432, "", function() end)
        SettingsTab:AddButton("Terapkan Background", 10723344432, function()
            local link = bgLinkInput:GetValue()
            local img = ParseImageLink(link)
            if not img or img == "" then
                if self._uiRefs.CustomBackground then self._uiRefs.CustomBackground.Visible = false end
                self:Notify("Background", "Background custom dihapus.", "info")
                return
            end
            if self._uiRefs.CustomBackground then
                self._uiRefs.CustomBackground.Image = img
                self._uiRefs.CustomBackground.Visible = true
            end
            self:Notify("Background", "Background custom diterapkan.", "success")
        end)

        local gradToggle = SettingsTab:AddToggle("Gradasi Merah ke Biru", 10723344432, false, function(state)
            if self._uiRefs.CustomBackgroundGradient then
                self._uiRefs.CustomBackgroundGradient.Visible = state
            end
        end)

        SettingsTab:AddButton("Hapus Background", 10723344432, function()
            bgLinkInput.Box.Text = ""
            if self._uiRefs.CustomBackground then self._uiRefs.CustomBackground.Visible = false end
            if self._uiRefs.CustomBackgroundGradient then self._uiRefs.CustomBackgroundGradient.Visible = false end
            if gradToggle and gradToggle.SetValue then gradToggle:SetValue(false) end
            self:Notify("Background", "Background direset.", "success")
        end)

        SettingsTab:AddSectionDivider("Profile Manager")
        local profileInput = SettingsTab:AddInput("Nama Profile", 10723344432, "setup_1", function() end)
        local saveDrop = SettingsTab:AddDropdown("Profile Tersimpan", 10723344432, {"Tidak ada profile"}, "Tidak ada profile", function() end)
        self.SaveDropdown = saveDrop

        -- Action buttons row
        local ActionRow = New("Frame", {
            Name = "ProfileActions",
            Size = UDim2.new(1,-4,0,34),
            BackgroundTransparency = 1,
            Parent = SettingsTab.ScrollBox,
        })
        New("UIListLayout", {
            FillDirection = Enum.FillDirection.Horizontal,
            Padding = UDim.new(0,5),
            Parent = ActionRow,
        })

        local function ActionBtn(label, color, order, cb)
            local Btn = New("TextButton", {
                LayoutOrder = order,
                Size = UDim2.new(1/3,-4,1,0),
                BackgroundColor3 = color,
                BackgroundTransparency = 0.15,
                Text = label,
                TextColor3 = Color3.fromRGB(240,240,240),
                TextSize = 11,
                Font = Enum.Font.GothamBold,
                BorderSizePixel = 0,
                Parent = ActionRow,
            })
            Corner(Btn, 7)
            Stroke(Btn, color, 1, 0.4)
            Btn.MouseEnter:Connect(function() TFast(Btn, { BackgroundTransparency = 0 }) end)
            Btn.MouseLeave:Connect(function() TFast(Btn, { BackgroundTransparency = 0.15 }) end)
            Btn.MouseButton1Click:Connect(function()
                TFast(Btn, { BackgroundTransparency = 0.5 })
                task.wait(0.1)
                TFast(Btn, { BackgroundTransparency = 0.15 })
                pcall(cb)
            end)
        end

        ActionBtn("Simpan", T.Success, 1, function()
            local n = profileInput:GetValue()
            if n == "" or n == "setup_1" then self:Notify("Gagal", "Isi nama profile dahulu.", "warning"); return end
            self:SaveProfile(n)
        end)
        ActionBtn("Muat", T.AccentBright, 2, function()
            local s = saveDrop:GetValue()
            if not s or s == "Tidak ada profile" then self:Notify("Gagal", "Pilih profile dari dropdown.", "warning"); return end
            self:LoadProfile(s)
        end)
        ActionBtn("Hapus", T.Error, 3, function()
            local s = saveDrop:GetValue()
            if not s or s == "Tidak ada profile" then self:Notify("Gagal", "Pilih profile dari dropdown.", "warning"); return end
            self:DeleteProfile(s)
        end)

        SettingsTab:AddButton("Refresh Daftar", 10723344432, function()
            self:RefreshSaveProfiles()
            self:Notify("Profile", "Daftar diperbarui.", "success")
        end)

        self:RefreshSaveProfiles()
        self:ApplyTheme()
    end)

    return self
end

