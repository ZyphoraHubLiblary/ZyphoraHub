-- Slider
function TabClass:AddSlider(text, iconId, min, max, default, callback)
    local T   = self.Library.Theme
    local val = default or min
    local act = callback or function() end

    local El = New("Frame", {
        Name = text .. "_Slider",
        Size = UDim2.new(1,-4,0,54),
        BackgroundColor3 = T.Surface,
        BorderSizePixel = 0,
        Parent = self.ScrollBox,
    })
    Corner(El, 8)
    local ElStroke = Stroke(El, T.Border, 1)

    local Label = New("TextLabel", {
        Size = UDim2.new(1,-60,0,18),
        Position = UDim2.new(0,12,0,7),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = T.Text,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = El,
    })

    local ValLbl = New("TextLabel", {
        Size = UDim2.new(0,50,0,18),
        Position = UDim2.new(1,-58,0,7),
        BackgroundTransparency = 1,
        Text = tostring(val),
        TextColor3 = T.AccentBright,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = El,
    })

    local Track = New("Frame", {
        Name = "Track",
        Size = UDim2.new(1,-24,0,6),
        Position = UDim2.new(0,12,0,34),
        BackgroundColor3 = T.SurfaceHigh,
        BorderSizePixel = 0,
        Parent = El,
    })
    Corner(Track, 3)

    local Fill = New("Frame", {
        Size = UDim2.new((val-min)/(max-min),0,1,0),
        BackgroundColor3 = T.Accent,
        BorderSizePixel = 0,
        Parent = Track,
    })
    Corner(Fill, 3)

    -- Thumb
    local Thumb = New("Frame", {
        Name = "Thumb",
        Size = UDim2.new(0,14,0,14),
        Position = UDim2.new((val-min)/(max-min),0,0.5,-7),
        AnchorPoint = Vector2.new(0.5,0),
        BackgroundColor3 = Color3.fromRGB(255,255,255),
        BorderSizePixel = 0,
        Parent = Track,
    })
    Corner(Thumb, 50)
    Stroke(Thumb, T.Accent, 2)

    local HitBox = New("TextButton", {
        Size = UDim2.new(1,0,1,24),
        Position = UDim2.new(0,0,0,-12),
        BackgroundTransparency = 1,
        Text = "",
        ZIndex = 5,
        Parent = Track,
    })

    local dragging = false

    local function Update(x)
        local abs = Track.AbsolutePosition.X
        local sz  = Track.AbsoluteSize.X
        if sz <= 0 then return end
        local pct = math.clamp((x-abs)/sz, 0, 1)
        val = math.floor(min + (max-min)*pct + 0.5)
        TFast(Fill, { Size = UDim2.new(pct,0,1,0) })
        Thumb.Position = UDim2.new(pct,0,0.5,-7)
        ValLbl.Text = tostring(val)
        pcall(act, val)
    end

    HitBox.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
            dragging = true; Update(inp.Position.X)
        end
    end)
    HitBox.InputChanged:Connect(function(inp)
        if dragging and (inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch) then
            Update(inp.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if not dragging then return end
        if inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch then Update(inp.Position.X) end
    end)

    El.MouseEnter:Connect(function() TFast(ElStroke, { Color = T.BorderLight }) end)
    El.MouseLeave:Connect(function() TFast(ElStroke, { Color = T.Border }) end)

    table.insert(self.Library.ControlRegistry, { Kind = "Slider", Root = El, RootStroke = ElStroke, Title = Label, Track = Track })
    table.insert(self.Elements, { Name = text, Instance = El })

    return {
        GetValue = function() return val end,
        SetValue = function(v)
            val = math.clamp(v, min, max)
            local pct = (val-min)/(max-min)
            Fill.Size = UDim2.new(pct,0,1,0)
            Thumb.Position = UDim2.new(pct,0,0.5,-7)
            ValLbl.Text = tostring(val)
        end
    }
end

