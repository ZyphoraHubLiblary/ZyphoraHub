    -- 9. NOTIFICATION QUEUE LIMIT
    -- ════════════════════════════════════════════════════════════
    -- Patch Notify supaya max N notif tampil sekaligus; sisanya
    -- masuk antrian dan tampil bertahap.
    function ZyphoraLibrary:SetNotifLimit(maxVisible)
        maxVisible = maxVisible or 3
        self._notifMax = maxVisible
        self._notifQueue = self._notifQueue or {}
        self._notifActive = self._notifActive or 0

        local OriginalNotify = self.Notify

        self.Notify = function(self2, title, text, ntype, duration)
            local function fire()
                self2._notifActive = (self2._notifActive or 0) + 1
                OriginalNotify(self2, title, text, ntype, duration)
                task.delay((duration or 3.5) + 0.4, function()
                    self2._notifActive = math.max(0, (self2._notifActive or 1) - 1)
                    if #self2._notifQueue > 0 and self2._notifActive < self2._notifMax then
                        local nxt = table.remove(self2._notifQueue, 1)
                        nxt()
                    end
                end)
            end

            if (self2._notifActive or 0) < self2._notifMax then
                fire()
            else
                table.insert(self2._notifQueue, fire)
            end
        end
    end


