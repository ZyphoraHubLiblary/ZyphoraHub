function ZyphoraLibrary:RefreshSaveProfiles()
    if not self.SaveDropdown then return end
    local list = {}
    if listfiles and isfolder and isfolder(self.SaveFolder) then
        for _, file in ipairs(listfiles(self.SaveFolder)) do
            if file:sub(-5) == ".json" then
                local name = file:match("([^/%\\]+)%.json$")
                if name then table.insert(list, name) end
            end
        end
    end
    table.sort(list, function(a,b) return a:lower() < b:lower() end)
    if #list == 0 then list = { "Tidak ada profile" } end
    if self.SaveDropdown.SetOptions then
        self.SaveDropdown:SetOptions(list, list[1], false)
    end
end

function ZyphoraLibrary:SaveProfile(profileName)
    if not writefile then self:Notify("Gagal", "Executor tidak support writefile.", "error"); return false end
    EnsureFolder(self.SaveFolder)
    local safe = SanitizeName(profileName)
    local data = {
        Theme = {},
        Toggles = self.ToggleStates or {}
    }
    for k,v in pairs(self.Theme) do
        if typeof(v) == "Color3" then data.Theme[k] = ColorToHex(v) end
    end
    pcall(writefile, self.SaveFolder .. "/" .. safe .. ".json", HttpService:JSONEncode(data))
    self:Notify("Profile Disimpan", '"' .. safe .. '" berhasil disimpan.', "success")
    self:RefreshSaveProfiles()
    return true
end

function ZyphoraLibrary:DeleteProfile(profileName)
    if not delfile then self:Notify("Gagal", "Executor tidak support delfile.", "error"); return false end
    local safe = SanitizeName(profileName)
    local path = self.SaveFolder .. "/" .. safe .. ".json"
    if not FileExists(path) then self:Notify("Gagal", "Profile tidak ditemukan.", "error"); return false end
    local ok = pcall(delfile, path)
    if not ok then self:Notify("Gagal", "Profile gagal dihapus.", "error"); return false end
    self:Notify("Profile Dihapus", '"' .. safe .. '" berhasil dihapus.', "error")
    self:RefreshSaveProfiles()
    return true
end

function ZyphoraLibrary:LoadProfile(profileName)
    if not readfile then self:Notify("Gagal", "Executor tidak support readfile.", "error"); return false end
    local safe = SanitizeName(profileName)
    local path = self.SaveFolder .. "/" .. safe .. ".json"
    if not FileExists(path) then self:Notify("Gagal", "Profile tidak ditemukan.", "error"); return false end
    local ok, raw = pcall(readfile, path)
    if not ok then self:Notify("Gagal", "File gagal dibaca.", "error"); return false end
    local okD, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if not okD or type(data) ~= "table" then self:Notify("Gagal", "Format profile invalid.", "error"); return false end
    if data.Theme then
        for k,v in pairs(data.Theme) do self.Theme[k] = HexToColor(v, self.Theme[k]) end
    end
    if data.Toggles then
        for name,value in pairs(data.Toggles) do
            local reg = self.ToggleRegistry and self.ToggleRegistry[name]
            if reg and reg.SetState then reg.SetState(value, true) end
        end
    end
    self:ApplyTheme(self.Theme)
    self:Notify("Profile Dimuat", '"' .. safe .. '" berhasil dimuat.', "success")
    return true
end

