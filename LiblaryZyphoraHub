        BorderSizePixel = 0,
        Parent = Cat,
    })

    local CatChip = New("Frame", {
        Size = UDim2.new(0,0,1,0),
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundColor3 = T.BGTertiary,
        BorderSizePixel = 0,
        Parent = Cat,
    })
    local CatTxt = New("TextLabel", {
        Size = UDim2.new(0,0,1,0),
