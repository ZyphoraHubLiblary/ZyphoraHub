local ICON_SUPPORT_URL = "https://raw.githubusercontent.com/ZyphoraHubLiblary/ZyphoraHubIconSupport/refs/heads/main/Icon%20Support"
local IconSupport = {}
pcall(function() IconSupport = loadstring(game:HttpGet(ICON_SUPPORT_URL))() end)

local function ResolveIcon(icon)
    if not icon then return nil end
    if typeof(icon) == "number" then return "rbxassetid://" .. tostring(icon) end
    if typeof(icon) == "string" then
        if icon:match("^rbxassetid://") or icon:match("^http") then return icon end
        local fixed = IconSupport[icon]
            or IconSupport[icon:sub(1,1):upper() .. icon:sub(2)]
            or IconSupport[string.upper(icon)]
        if fixed then return fixed end
    end
    return nil
end

-- ─────────────────────────────────────────
--  UTILITIES
-- ─────────────────────────────────────────
local function Clamp255(n) return math.clamp(math.floor(tonumber(n) or 0), 0, 255) end
local function ColorToHex(c) return string.format("#%02X%02X%02X", Clamp255(c.R*255), Clamp255(c.G*255), Clamp255(c.B*255)) end
local function HexToColor(hex, fallback)
    if typeof(hex) ~= "string" then return fallback end
    hex = hex:gsub("#",""):gsub("0x","")
    if #hex ~= 6 then return fallback end
    local r,g,b = tonumber(hex:sub(1,2),16), tonumber(hex:sub(3,4),16), tonumber(hex:sub(5,6),16)
    if not r or not g or not b then return fallback end
    return Color3.fromRGB(r,g,b)
end
local function ParseImageLink(input)
    if typeof(input) ~= "string" then return nil end
    local s = input:gsub("%s+", "")
    if s == "" then return nil end

    if s:match("^rbxassetid://%d+$") then return s end
    if s:match("^%d+$") then return "rbxassetid://" .. s end

    local idFromUrl = s:match("roblox%.com/[^%s]-(%d+)")
    if idFromUrl then return "rbxassetid://" .. idFromUrl end

    if s:match("^https?://") and s:match("%.%a+$") then
        return s
    end

    local anyId = s:match("(%d+)")
    if anyId then return "rbxassetid://" .. anyId end

    return s
end
local function SanitizeName(name)
    name = tostring(name or ""):gsub("[%/%:*%?\"<>|]",""):gsub("%s+",""):gsub("[%+%^%$]","")
    return name == "" and "Profile" or name
end
local function FileExists(path) if isfile then local ok,r = pcall(isfile,path); return ok and r end return false end
local function EnsureFolder(path) if makefolder and not isfolder(path) then pcall(makefolder,path) end end

