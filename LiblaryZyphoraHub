    -- 10. RESIZE HANDLE
    -- ════════════════════════════════════════════════════════════
    function ZyphoraLibrary:EnableResize(minSize, maxSize)
        minSize = minSize or Vector2.new(380, 240)
        maxSize = maxSize or Vector2.new(900, 700)

        local T = self.Theme
        local MainFrame = self.MainFrame

        local Handle = New("Frame", {
            Name = "ResizeHandle",
            Size = UDim2.new(0,16,0,16),
            Position = UDim2.new(1,-16,1,-16),
            BackgroundTransparency = 1,
            ZIndex = 20,
            Parent = MainFrame,
        })

        -- Visual grip dots
        local Grip = New("ImageLabel", {
            Size = UDim2.new(1,0,1,0),
            BackgroundTransparency = 1,
            Image = "rbxassetid://3926305904", -- generic icon sheet fallback
            ImageRectOffset = Vector2.new(0,0),
            ImageRectSize = Vector2.new(0,0),
            ImageTransparency = 1,
            Parent = Handle,
        })
        -- Simple diagonal lines using frames instead (more reliable than icon)
        for i=1,3 do
            New("Frame", {
                Size = UDim2.new(0, 2, 0, 2*i),
                Position = UDim2.new(1, -4-(i*4), 1, -4),
                AnchorPoint = Vector2.new(1,1),
                BackgroundColor3 = T.TextMuted,
                BorderSizePixel = 0,
                Rotation = 45,
                Parent = Handle,
            })
        end

        local HandleBtn = New("TextButton", {
            Size = UDim2.new(1,0,1,0),
            BackgroundTransparency = 1,
            Text = "",
            Parent = Handle,
        })

        local dragging = false
        local startMouse, startSize

        HandleBtn.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                startMouse = inp.Position
                startSize = MainFrame.AbsoluteSize
            end
        end)
        UserInputService.InputEnded:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
                dragging = false
            end
        end)
        UserInputService.InputChanged:Connect(function(inp)
            if not dragging then return end
            if inp.UserInputType ~= Enum.UserInputType.MouseMovement and inp.UserInputType ~= Enum.UserInputType.Touch then return end
            local delta = inp.Position - startMouse
            local newW = math.clamp(startSize.X + delta.X, minSize.X, maxSize.X)
            local newH = math.clamp(startSize.Y + delta.Y, minSize.Y, maxSize.Y)
            MainFrame.Size = UDim2.new(0, newW, 0, newH)
        end)

        HandleBtn.MouseEnter:Connect(function()
            for _, c in ipairs(Handle:GetChildren()) do
                if c:IsA("Frame") then TFast(c, { BackgroundColor3 = T.AccentBright }) end
            end
        end)
        HandleBtn.MouseLeave:Connect(function()
            for _, c in ipairs(Handle:GetChildren()) do
                if c:IsA("Frame") then TFast(c, { BackgroundColor3 = T.TextMuted }) end
            end
        end)

        return Handle
    end


    -- ════════════════════════════════════════════════════════════
    -- 11. RGB / RAINBOW ACCENT MODE
    -- ════════════════════════════════════════════════════════════
    function ZyphoraLibrary:EnableRainbowAccent(speed)
        speed = speed or 0.3 -- hue shift per second

        if self._rainbowConn then return end -- already running

        self._rainbowEnabled = true
        local hue = 0

        self._rainbowConn = RunService.Heartbeat:Connect(function(dt)
            if not self._rainbowEnabled then return end
            hue = (hue + dt * speed) % 1
            local accent = Color3.fromHSV(hue, 0.75, 1)
            local bright = Color3.fromHSV(hue, 0.55, 1)
            local dim    = Color3.fromHSV(hue, 0.85, 0.7)

            self.Theme.Accent = accent
            self.Theme.AccentBright = bright
            self.Theme.AccentDim = dim
            self.Theme.ToggleOn = accent

            self:ApplyTheme()
        end)
    end

    function ZyphoraLibrary:DisableRainbowAccent()
        self._rainbowEnabled = false
        if self._rainbowConn then
            self._rainbowConn:Disconnect()
            self._rainbowConn = nil
        end
    end

return ZyphoraLibrary
