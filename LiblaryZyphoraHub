-- ─────────────────────────────────────────
function ZyphoraLibrary:Notify(notifTitle, notifText, notifType, duration)
    local viewTime = duration or 3.5
    local T = self.Theme

    local typeColors = {
        success = T.Success,
        error   = T.Error,
        warning = T.Warning,
    }
    local accentColor = typeColors[notifType] or T.Accent

    local Box = New("Frame", {
        Name = "ZyphoraNotif",
        Size = UDim2.new(1,0,0,64),
        Position = UDim2.new(1,20,0,0),
        BackgroundColor3 = T.Surface,
        BorderSizePixel = 0,
        ClipsDescendants = true,
        Parent = self.NotifHolder,
    })
    Corner(Box, 10)
    Stroke(Box, accentColor, 1, 0.2)

    -- Glass shimmer
    local BoxGrad = New("Frame", {
        Size = UDim2.new(1,0,0.5,0),
        BackgroundColor3 = Color3.fromRGB(255,255,255),
        BackgroundTransparency = 0.97,
        BorderSizePixel = 0,
        Parent = Box,
    })
    Corner(BoxGrad, 10)

    -- Left accent bar
    local AccBar = New("Frame", {
        Size = UDim2.new(0,3,1,-16),
        Position = UDim2.new(0,0,0,8),
        BackgroundColor3 = accentColor,
        BorderSizePixel = 0,
        Parent = Box,
    })
    Corner(AccBar, 2)

    -- Icon
    local NIco = New("ImageLabel", {
        Size = UDim2.new(0,16,0,16),
        Position = UDim2.new(0,14,0,14),
        BackgroundTransparency = 1,
        Image = ResolveIcon(10734950309) or "",
        ImageColor3 = accentColor,
        Parent = Box,
    })

    New("TextLabel", {
        Size = UDim2.new(1,-44,0,20),
        Position = UDim2.new(0,36,0,12),
        BackgroundTransparency = 1,
        Text = tostring(notifTitle),
        TextColor3 = T.Text,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = Box,
    })

    New("TextLabel", {
        Size = UDim2.new(1,-22,0,20),
        Position = UDim2.new(0,14,0,34),
        BackgroundTransparency = 1,
        Text = tostring(notifText),
        TextColor3 = T.TextDim,
        TextSize = 10,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        Parent = Box,
    })

    -- Progress bar
    local ProgBg = New("Frame", {
        Size = UDim2.new(1,0,0,2),
        Position = UDim2.new(0,0,1,-2),
        BackgroundColor3 = T.SurfaceHigh,
        BorderSizePixel = 0,
        Parent = Box,
    })
    local Prog = New("Frame", {
        Size = UDim2.new(1,0,1,0),
        BackgroundColor3 = accentColor,
        BorderSizePixel = 0,
        Parent = ProgBg,
    })
    Tween(Prog, TI(viewTime, Enum.EasingStyle.Linear), { Size = UDim2.new(0,0,1,0) })

    -- Slide in
    TSpring(Box, { Position = UDim2.new(0,0,0,0) })

    task.delay(viewTime, function()
        if not Box or not Box.Parent then return end
        local tw = TSlow(Box, { Position = UDim2.new(1,20,0,0), BackgroundTransparency = 1 })
        if tw then
            tw.Completed:Connect(function() if Box then Box:Destroy() end end)
        else
            task.wait(0.3)
            if Box then Box:Destroy() end
        end
    end)
end

