    -- 7. CONFIG AUTO-SAVE
    -- ════════════════════════════════════════════════════════════
    -- Mengaktifkan auto-save: setiap toggle berubah, langsung
    -- ditulis ke file config (default profile bernama "autosave").
    function ZyphoraLibrary:EnableAutoSave(profileName, debounceSeconds)
        profileName = profileName or "autosave"
        debounceSeconds = debounceSeconds or 1

        self._autoSaveProfile = profileName
        self._autoSavePending = false

        local function DoSave()
            self._autoSavePending = false
            self:SaveProfile(profileName)
        end

        -- Hook ke semua toggle yang sudah / akan terdaftar
        local origSetState = {}
        for name, reg in pairs(self.ToggleRegistry or {}) do
            local orig = reg.SetState
            reg.SetState = function(v, fire)
                orig(v, fire)
                if not self._autoSavePending then
                    self._autoSavePending = true
                    task.delay(debounceSeconds, DoSave)
                end
            end
        end

        -- Untuk toggle baru yang ditambahkan SETELAH EnableAutoSave dipanggil,
        -- bungkus AddToggle agar otomatis ikut ter-hook.
        local OriginalAddToggle = TabClass.AddToggle
        TabClass.AddToggle = function(self2, text, iconId, defaultState, callback)
            local wrapped = function(state)
                if callback then pcall(callback, state) end
                if not self2.Library._autoSavePending then
                    self2.Library._autoSavePending = true
                    task.delay(debounceSeconds, function()
                        self2.Library._autoSavePending = false
                        self2.Library:SaveProfile(self2.Library._autoSaveProfile)
                    end)
                end
            end
            return OriginalAddToggle(self2, text, iconId, defaultState, wrapped)
        end

        -- Coba load config tersimpan
        if FileExists and self.SaveFolder then
            local path = self.SaveFolder .. "/" .. profileName .. ".json"
            if isfile and isfile(path) then
                self:LoadProfile(profileName)
            end
        end

        self:Notify("Auto-Save", "Config otomatis tersimpan ke profile \"" .. profileName .. "\".", "info")
    end


