-- ─────────────────────────────────────────
--  APPLY THEME
-- ─────────────────────────────────────────
function ZyphoraLibrary:ApplyTheme(theme)
    theme = theme or self.Theme
    self.Theme = theme

    local T = theme

    if self._uiRefs then
        local R = self._uiRefs
        if R.MainFrame then
            R.MainFrame.BackgroundColor3 = T.BG
            if R.MainStroke then R.MainStroke.Color = T.Border end
        end
        if R.TopBar then
            R.TopBar.BackgroundColor3 = T.BGSecondary
        end
        if R.SidebarBg then
            R.SidebarBg.BackgroundColor3 = T.BGTertiary
        end
        if R.SidebarDiv then
            R.SidebarDiv.BackgroundColor3 = T.Border
        end
        if R.SearchBar then
            R.SearchBar.BackgroundColor3 = T.Surface
            if R.SearchBarStroke then R.SearchBarStroke.Color = T.Border end
            if R.SearchIcon then R.SearchIcon.ImageColor3 = T.TextMuted end
            if R.SearchBox then
                R.SearchBox.TextColor3 = T.Text
                R.SearchBox.PlaceholderColor3 = T.TextMuted
            end
        end
    end

    for _, tab in ipairs(self.Tabs or {}) do
        local isActive = tab == self.CurrentTab
        if tab.Button then
            tab.Button.BackgroundColor3 = isActive and T.SurfaceHigh or T.Surface
        end
        if tab.Label then
            tab.Label.TextColor3 = isActive and T.AccentBright or T.TextDim
        end
        if tab.Icon then
            tab.Icon.ImageColor3 = isActive and T.AccentBright or T.TextMuted
        end
        if tab.ActiveLine then
            tab.ActiveLine.BackgroundColor3 = isActive and T.Accent or Color3.fromRGB(0,0,0)
            tab.ActiveLine.BackgroundTransparency = isActive and 0 or 1
        end
    end

    for _, ref in ipairs(self.ControlRegistry or {}) do
        if not (ref.Root and ref.Root.Parent) then continue end
        ref.Root.BackgroundColor3 = T.Surface
        if ref.RootStroke then ref.RootStroke.Color = T.Border end
        if ref.Title then ref.Title.TextColor3 = T.Text end
        if ref.Icon then ref.Icon.ImageColor3 = T.TextMuted end
        if ref.Kind == "Button" then
            if ref.BtnText then ref.BtnText.TextColor3 = T.Text end
        elseif ref.Kind == "Toggle" then
            if ref.TText then ref.TText.TextColor3 = T.Text end
        elseif ref.Kind == "Dropdown" then
            ref.Root.BackgroundColor3 = T.Surface
            if ref.ValLabel then ref.ValLabel.TextColor3 = T.TextDim end
        elseif ref.Kind == "Input" then
            ref.Root.BackgroundColor3 = T.Surface
            if ref.Box then
                ref.Box.TextColor3 = T.Text
                ref.Box.PlaceholderColor3 = T.TextMuted
            end
        elseif ref.Kind == "Label" then
            ref.Root.BackgroundColor3 = T.BGSecondary
            if ref.Sub then ref.Sub.TextColor3 = T.TextMuted end
        elseif ref.Kind == "Slider" then
            if ref.Track then ref.Track.BackgroundColor3 = T.SurfaceHigh end
        elseif ref.Kind == "Section" then
            if ref.Line then ref.Line.BackgroundColor3 = T.Border end
            if ref.Txt then ref.Txt.TextColor3 = T.TextMuted end
        end
    end
end

