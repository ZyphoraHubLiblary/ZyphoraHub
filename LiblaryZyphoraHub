--  CREATE TAB
-- ─────────────────────────────────────────
function ZyphoraLibrary:CreateTab(tabName, iconId, isPinned, targetCategory)
    local T = self.Theme
    local tab = setmetatable({ Library = self, Elements = {} }, TabClass)

    local TabButton = New("TextButton", {
        Name = tabName .. "_Tab",
        BackgroundColor3 = T.Surface,
        Text = "",
        BorderSizePixel = 0,
        AutoButtonColor = false,
    })
    Corner(TabButton, 7)

    -- Active indicator line (left side)
    local ActiveLine = New("Frame", {
        Name = "ActiveLine",
        Size = UDim2.new(0,3,1,-16),
        Position = UDim2.new(0,0,0,8),
        BackgroundColor3 = T.Accent,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ZIndex = 2,
        Parent = TabButton,
    })
    Corner(ActiveLine, 2)
    tab.ActiveLine = ActiveLine

    if isPinned then
        TabButton.Size = UDim2.new(0,122,0,30)
        TabButton.Position = UDim2.new(0,4,1,-36)
        TabButton.Parent = self.MainFrame
    else
        TabButton.Size = UDim2.new(1,-6,0,30)
        local n = 0
        for _,c in ipairs(self.Sidebar:GetChildren()) do
            if c:IsA("Frame") or c:IsA("TextButton") then n=n+1 end
        end
        TabButton.LayoutOrder = n + 1
        TabButton.Parent = self.Sidebar
        if targetCategory and self.Categories[targetCategory] then
            self.Categories[targetCategory]:LinkTab(TabButton)
        end
    end

    if iconId then
        local TabIcon = New("ImageLabel", {
            Name = "TabIcon",
            Size = UDim2.new(0,14,0,14),
            Position = UDim2.new(0,12,0.5,-7),
            BackgroundTransparency = 1,
            Image = ResolveIcon(iconId) or "",
            ImageColor3 = T.TextMuted,
            Parent = TabButton,
        })
        tab.Icon = TabIcon
    end

    local TabLabel = New("TextLabel", {
        Name = "TabLabel",
        Size = UDim2.new(1, iconId and -34 or -18, 1, 0),
        Position = UDim2.new(0, iconId and 32 or 10, 0, 0),
        BackgroundTransparency = 1,
        Text = tabName,
        TextColor3 = T.TextDim,
        TextSize = 11,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = TabButton,
    })
    tab.Label = TabLabel
    tab.Button = TabButton

    local ScrollBox = New("ScrollingFrame", {
        Name = tabName .. "_Scroll",
        Size = UDim2.new(1,-4,1,-2),
        Position = UDim2.new(0,2,0,1),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = T.Border,
        CanvasSize = UDim2.new(0,0,0,0),
        Visible = false,
        Parent = self.ContentHolder,
    })
    tab.ScrollBox = ScrollBox

    local Layout = New("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0,5),
        Parent = ScrollBox,
    })
    Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        ScrollBox.CanvasSize = UDim2.new(0,0,0, Layout.AbsoluteContentSize.Y + 10)
    end)

    local function Activate()
        if not TabButton.Visible then return end
        for _, t in ipairs(self.Tabs) do
            if t.ScrollBox then t.ScrollBox.Visible = false end
            if t.Button then TFast(t.Button, { BackgroundColor3 = T.Surface }) end
            if t.Label then TFast(t.Label, { TextColor3 = T.TextDim }) end
            if t.Icon then TFast(t.Icon, { ImageColor3 = T.TextMuted }) end
            if t.ActiveLine then TFast(t.ActiveLine, { BackgroundTransparency = 1 }) end
        end
        ScrollBox.Visible = true
        TFast(TabButton, { BackgroundColor3 = T.SurfaceHigh })
        TFast(TabLabel, { TextColor3 = T.AccentBright })
        if tab.Icon then TFast(tab.Icon, { ImageColor3 = T.AccentBright }) end
        TFast(ActiveLine, { BackgroundTransparency = 0 })
        self.CurrentTab = tab
        self:RefreshCurrentSearch()
    end

    TabButton.MouseButton1Click:Connect(Activate)
    TabButton.MouseEnter:Connect(function()
        if self.CurrentTab ~= tab then TFast(TabButton, { BackgroundColor3 = T.SurfaceHigh }) end
    end)
    TabButton.MouseLeave:Connect(function()
        if self.CurrentTab ~= tab then TFast(TabButton, { BackgroundColor3 = T.Surface }) end
    end)

    table.insert(self.Tabs, tab)
    if #self.Tabs == 1 and tabName ~= "Credits" then Activate() end
    self:ApplyTheme()
    return tab
end

